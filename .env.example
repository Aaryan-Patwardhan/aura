# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aura
POSTGRES_USER=aura
POSTGRES_PASSWORD=aura_secret

# Redis
REDIS_URL=redis://redis:6379/0

# Ingestion API
INGESTION_HOST=0.0.0.0
INGESTION_PORT=8000
AURA_API_KEY=dev_secret_key
CORS_ORIGINS=http://localhost:3000

# AI Model
MODEL_PATH=/app/ai/models/isolation_forest.pkl

# Dashboard API base URL (used by Vite at build time)
VITE_API_BASE_URL=http://localhost:8000
VITE_AURA_API_KEY=dev_secret_key
